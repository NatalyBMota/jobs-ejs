<%- include("../partials/head.ejs") %>
<%- include("../partials/header.ejs") %>
  <h2>edit job</h2>
  <% if (message) { %><p><%= message %></p><% } %>

  <form method="POST" action="/friendsBday/update/<%= job._id %>">
  <table id="jobs-form-table">
    <tr>
      <th colspan="2">Edit Job</th>
    </tr>
    <tr>
      <td><label for="company">company:</label></td>
      <td><input type="text" id="company" name="company" value="<%= job.company %>" required /></td>
    </tr>
    <tr>
      <td><label for="position">position:</label></td>
      <td><input type="text" id="position" name="position" value="<%= job.position %>" required /></td>
    </tr>
    <tr>
      <td><label for="month">Month:</label></td>
      <td>
        <select id="month" name="month">
          <option value="January" <%= job.status === 'January' ? 'selected' : '' %>>January</option>
          <option value="February" <%= job.status === 'February' ? 'selected' : '' %>>February</option>
          <option value="March" <%= job.status === 'March' ? 'selected' : '' %>>March</option>
          <option value="April" <%= job.status === 'April' ? 'selected' : '' %>>April</option>
          <option value="May" <%= job.status === 'May' ? 'selected' : '' %>>May</option>
          <option value="June" <%= job.status === 'June' ? 'selected' : '' %>>June</option>
          <option value="July" <%= job.status === 'July' ? 'selected' : '' %>>July</option>
          <option value="August" <%= job.status === 'August' ? 'selected' : '' %>>August</option>
          <option value="September" <%= job.status === 'September' ? 'selected' : '' %>>September</option>
          <option value="October" <%= job.status === 'October' ? 'selected' : '' %>>October</option>
          <option value="November" <%= job.status === 'November' ? 'selected' : '' %>>November</option>
          <option value="December" <%= job.status === 'December' ? 'selected' : '' %>>December</option>
        </select>
      </td>
    </tr>
    <tr>
      <td><label for="day">Day (numeric):</label></td>
      <td><input type="number" id="day" name="day" min="1" max="31" step="1" value="<%= job.day %>" required /></td>
    </tr>
    <tr>
      <td colspan="2">
        <% if (locals._csrf) { %>
          <input type="hidden" name="_csrf" value="<%= locals._csrf %>" />
        <% } %>
        <button type="submit">update</button>
        <a href="/friendsBday"><button type="button">cancel</button></a>
      </td>
    </tr>
  </table>
</form>
<script src="/birthdayValidation.js"></script>
<%- include("../partials/footer.ejs") %>